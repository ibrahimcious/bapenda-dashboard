DATABASE_URL=postgresql://tanstack:tanstack@localhost:5678/tanstack
APP_URL=http://localhost:3000
# Required in production — better-auth reads this automatically. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Cloudflare R2 (S3-compatible object storage) — used to serve the in-app PDF viewer
# Create a scoped, read-only R2 API Token via Cloudflare dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# Per-document R2 keys now live in src/modules/documents/documents.config.ts
